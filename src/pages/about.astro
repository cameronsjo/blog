---
import BaseLayout from '../layouts/BaseLayout.astro';
import { GITHUB_URL } from '../consts';
---

<BaseLayout
  title="About"
  description="Cameron Sjo — Principal Software Engineer working in AI security."
>
  <h1 class="post-title reveal mb-8 font-bold" style="--i: 0; color: var(--fg)">
    About
  </h1>
  <div class="prose reveal max-w-none" style="--i: 1">
    <p>
      I'm Cameron Sjo — a Principal Software Engineer working in AI security.
      My day job is threat modeling for LLM-based systems: guardrails,
      secure-by-design practices, and the policies that keep them honest.
    </p>
    <p>
      This is where I write about the rest of it — the building and the tuning.
      I tend toward self-hosted, privacy-first tools I understand well enough to
      rebuild, and I care more about how a system <em>feels</em> to use than how
      it benchmarks.
    </p>
    <p>
      Find the code on <a href={GITHUB_URL}>GitHub</a>.
    </p>
  </div>
</BaseLayout>

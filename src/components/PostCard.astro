---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import { withBase } from '../utils';

interface Props {
  post: CollectionEntry<'blog'>;
  index: number;
}

const { post, index } = Astro.props;
const href = withBase(`posts/${post.id}/`);
const num = String(index + 1).padStart(2, '0');
const tags = post.data.tags;
---

<a class="entry" href={href}>
  <span class="entry__rail">
    <span class="entry__num">{num}</span>
    <span class="entry__date"><FormattedDate date={post.data.pubDate} /></span>
  </span>
  <span class="entry__main">
    <h2 class="entry__title">{post.data.title}</h2>
    <span class="entry__desc">{post.data.description}</span>
  </span>
</a>
{
  /* Tag links live OUTSIDE the card anchor — nesting <a> inside <a> is invalid. */
  tags.length > 0 && (
    <ul class="entry__tags">
      {tags.map((tag) => (
        <li>
          <a class="entry__tag" href={withBase(`tags/${encodeURIComponent(tag)}/`)}>
            #{tag}
          </a>
        </li>
      ))}
    </ul>
  )
}

<style>
  .entry__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-xs, 0.4rem);
    margin: -0.5rem 0 0;
    /* Align under .entry__main: rail column (3.5rem) + grid gap. */
    padding: 0 0 0 calc(3.5rem + var(--s-lg));
    list-style: none;
  }
  @media (max-width: 640px) {
    .entry__tags {
      padding-left: 0;
    }
  }
  .entry__tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--fg-secondary);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease);
  }
  .entry__tag:hover {
    color: var(--accent);
  }
</style>

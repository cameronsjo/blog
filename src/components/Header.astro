---
import { SITE_WORDMARK } from '../consts';
import { withBase } from '../utils';

const path = Astro.url.pathname.replace(/\/$/, '');
const nav = [
  { href: withBase(''), label: 'Home' },
  { href: withBase('about'), label: 'About' },
  { href: withBase('search'), label: 'Search' },
];
---

<header
  class="flex items-center justify-between gap-4 border-b py-5"
  style="border-color: var(--border)"
>
  <a
    href={withBase('')}
    class="wordmark whimsy whimsy--brand font-mono text-lg font-bold"
    data-wordmark
  >
    {SITE_WORDMARK}
  </a>
  <nav class="flex items-center gap-5 text-sm">
    {
      nav.map((item) => {
        const active = path === item.href.replace(/\/$/, '');
        return (
          <a
            href={item.href}
            aria-current={active ? 'page' : undefined}
            style={active ? 'color: var(--fg)' : 'color: var(--fg-secondary)'}
          >
            {item.label}
          </a>
        );
      })
    }
    <button
      type="button"
      class="theme-toggle font-mono"
      data-theme-toggle
      aria-label="Toggle color theme"
    >
      <span class="dot" aria-hidden="true"></span>
      <span data-theme-label>Dark</span>
    </button>
  </nav>
</header>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--s-xs);
    padding: 4px 10px;
    font-size: 12px;
    color: var(--fg-secondary);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease),
      color var(--dur-fast) var(--ease);
  }
  .theme-toggle:hover {
    color: var(--fg);
    border-color: var(--accent);
  }
  .theme-toggle .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
  }
</style>

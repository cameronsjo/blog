---
import type { MarkdownHeading } from 'astro';
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { withBase } from '../utils';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  ogImage?: string;
  heroImage?: ImageMetadata;
  headings?: MarkdownHeading[];
  minutesRead?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  ogImage,
  heroImage,
  headings = [],
  minutesRead,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  pubDate={pubDate}
  updatedDate={updatedDate}
  ogImage={ogImage}
  tags={tags}
>
  <article class="prose max-w-none" data-pagefind-body>
    <header class="not-prose reveal mb-10" style="--i: 0">
      <h1 class="post-title mb-3 font-bold" style="color: var(--fg)">{title}</h1>
      <p class="text-sm" style="color: var(--fg-secondary)">
        <FormattedDate date={pubDate} />
        {updatedDate && (<span> · updated <FormattedDate date={updatedDate} /></span>)}
        {minutesRead && (<span> · {minutesRead}</span>)}
      </p>
      {
        tags.length > 0 && (
          <ul class="mt-3 flex flex-wrap gap-2 p-0">
            {tags.map((tag) => (
              <li class="list-none">
                <a
                  class="tag-chip rounded px-2 py-0.5 text-xs"
                  href={withBase(`tags/${encodeURIComponent(tag)}/`)}
                >
                  {tag}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </header>
    {
      heroImage && (
        <Image
          class="reveal mb-8 w-full rounded"
          style="--i: 1"
          src={heroImage}
          alt={`Hero image for ${title}`}
          widths={[480, 800, 1200]}
          sizes="(max-width: 42rem) 100vw, 42rem"
        />
      )
    }
    <TableOfContents headings={headings} />
    <div class="reveal" style="--i: 2">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .tag-chip {
    background: var(--bg-raised);
    color: var(--fg-secondary);
    text-decoration: none;
    transition:
      color var(--dur-fast) var(--ease),
      background var(--dur-fast) var(--ease);
  }
  .tag-chip:hover {
    color: var(--accent);
    background: var(--bg-overlay);
  }
</style>
